<!DOCTYPE html>
<html lang="zh-CN" xmlns:th="http://www.thymeleaf.org">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title th:text="${title} + ' - MyBlog'">后台管理 - MyBlog</title>
    <th:block th:replace="~{fragments :: siteHead}"></th:block>
</head>
<body>
    <th:block th:replace="~{fragments :: siteBackground}"></th:block>
    <th:block th:replace="~{fragments :: siteGridBg}"></th:block>
    <th:block th:replace="~{fragments :: siteNavbar('admin')}"></th:block>

    <main class="admin-dashboard">
        <section class="admin-hero">
            <h1 class="admin-hero-title">后台管理</h1>
            <p class="admin-hero-subtitle">在这里管理你的博客内容与数据</p>
        </section>

        <section class="admin-stats">
            <div class="admin-stat-card">
                <div class="admin-stat-icon"><i class="ri-article-line"></i></div>
                <div class="admin-stat-info">
                    <div class="admin-stat-value" th:text="${articleCount}">0</div>
                    <div class="admin-stat-label">已发布文章</div>
                </div>
            </div>
            <div class="admin-stat-card">
                <div class="admin-stat-icon"><i class="ri-eye-line"></i></div>
                <div class="admin-stat-info">
                    <div class="admin-stat-value" th:text="${totalViews}">0</div>
                    <div class="admin-stat-label">总浏览量</div>
                </div>
            </div>
            <div class="admin-stat-card">
                <div class="admin-stat-icon"><i class="ri-heart-line"></i></div>
                <div class="admin-stat-info">
                    <div class="admin-stat-value" th:text="${totalLikes}">0</div>
                    <div class="admin-stat-label">总点赞数</div>
                </div>
            </div>
        </section>

        <section class="admin-section">
            <div class="section-header">
                <h2 class="section-title">最近文章</h2>
            </div>
            <div class="admin-table-wrapper">
                <table class="admin-table">
                    <thead>
                        <tr>
                            <th>标题</th>
                            <th>状态</th>
                            <th>浏览</th>
                            <th>点赞</th>
                            <th>发布时间</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr th:each="article : ${recentArticles}">
                            <td>
                                <a th:href="@{/article/{id}(id=${article.id})}" th:text="${article.title}">文章标题</a>
                            </td>
                            <td>
                                <span class="admin-status" th:classappend="${article.status} == 1 ? 'published' : 'draft'"
                                      th:text="${article.status} == 1 ? '已发布' : '草稿'">已发布</span>
                            </td>
                            <td th:text="${article.viewCount}">0</td>
                            <td th:text="${article.likeCount}">0</td>
                            <td th:text="${article.createdTime}">2024-01-01</td>
                        </tr>
                        <tr th:if="${#lists.isEmpty(recentArticles)}">
                            <td colspan="5" class="admin-empty-cell">暂无文章</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </section>
    </main>

    <th:block th:replace="~{fragments :: siteFooter}"></th:block>
    <script th:src="@{/js/blog.js}"></script>
</body>
</html>
